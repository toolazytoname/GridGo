/* app.wxss - 微信小程序全局样式 - 与 mobile-ios.html 1:1 */

/* 设计 tokens（与 mobile-ios.html :root 一致） */
page {
  --bg: oklch(99% 0.002 240);
  --surface: oklch(100% 0 0);
  --surface-warm: oklch(98% 0.003 240);
  --fg: oklch(18% 0.012 250);
  --fg-2: oklch(28% 0.012 250);
  --muted: oklch(54% 0.012 250);
  --meta: oklch(72% 0.008 250);
  --border: oklch(92% 0.005 250);
  --border-soft: oklch(95% 0.004 250);
  --accent: oklch(58% 0.18 255);
  --accent-hover: oklch(52% 0.19 255);
  --accent-active: oklch(46% 0.20 255);
  --success: oklch(70% 0.16 145);
  --warning: oklch(70% 0.16 45);
  --danger: oklch(65% 0.20 25);
  --q1: var(--accent);
  --q2: var(--success);
  --q3: var(--warning);
  --q4: var(--muted);
  --space-1: 4px; --space-2: 8px; --space-3: 12px; --space-4: 16px; --space-5: 20px; --space-6: 24px;
  --radius-sm: 8px; --radius-md: 12px; --radius-pill: 999px;
  background: var(--bg);
  color: var(--fg);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 14px;
}

/* 通用 */
.view { padding: 0 16px 100px; }
.m-topbar { display: flex; align-items: center; padding: 10px 16px 8px; gap: 10px; background: var(--bg); }
.m-logo { height: 24px; width: 24px; }
.okr-chip { flex: 1; display: flex; align-items: center; gap: 4px; padding: 5px 10px; border-radius: 8px; background: var(--bg); border: 1px solid var(--border); font-size: 12px; font-weight: 500; }
.topbar-btn { width: 30px; height: 30px; border-radius: 8px; background: transparent; display: grid; place-items: center; }
.topbar-btn:active { background: oklch(94% 0.005 240); }

/* 二级 Tab */
.m-subtabs { display: flex; gap: 0; padding: 0 16px; background: rgba(250,250,247,.85); border-bottom: 1px solid var(--border); overflow-x: auto; }
.m-subtab { padding: 9px 12px; font-size: 12px; font-weight: 500; color: var(--muted); border-bottom: 2px solid transparent; white-space: nowrap; }
.m-subtab.active { color: var(--fg); border-bottom-color: var(--accent); font-weight: 600; }

/* 四象限 */
.eq2grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.eq2 { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 12px; min-height: 130px; }
.eq2.q1 { border-top: 2px solid var(--accent); }
.eq2.q2 { border-top: 2px solid var(--success); }
.eq2.q3 { border-top: 2px solid var(--warning); }
.eq2.q4 { border-top: 2px solid var(--muted); }
.eq2h { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.eq2l { font-size: 9px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); }
.eq2c { font-size: 9px; font-weight: 600; color: var(--muted); background: var(--bg); padding: 1px 5px; border-radius: 999px; }
.eq2t { display: flex; flex-direction: column; gap: 4px; }
.eq2item { display: flex; align-items: flex-start; gap: 6px; padding: 6px 8px; border-radius: 7px; background: var(--bg); }
.eq2item:active { background: oklch(94% 0.005 240); }
.eq2ck { width: 14px; height: 14px; border-radius: 50%; border: 1.5px solid var(--border); flex-shrink: 0; margin-top: 1px; }
.eq2ck.done { background: var(--success); border-color: var(--success); }
.eq2ck.done::after { content: ''; display: block; width: 5px; height: 5px; background: #fff; border-radius: 50%; margin: 2.5px auto 0; }
.eq2item-title { font-size: 11px; font-weight: 500; color: var(--fg); line-height: 1.35; flex: 1; }
.eq2item-title.done { text-decoration: line-through; color: var(--muted); }
.eq2tag { font-size: 9px; font-weight: 600; color: var(--accent); background: oklch(94% 0.008 255); padding: 1px 5px; border-radius: 3px; margin-top: 2px; display: inline-block; }

/* 列表 树 */
.okr-card { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; margin-bottom: 10px; overflow: hidden; }
.okr-h { display: flex; align-items: center; gap: 10px; padding: 12px 14px; }
.okr-exp { width: 18px; height: 18px; display: grid; place-items: center; color: var(--muted); transition: transform .2s; }
.okr-exp.open { transform: rotate(90deg); }
.okr-dot { width: 9px; height: 9px; border-radius: 50%; }
.okr-n { font-size: 13px; font-weight: 600; flex: 1; }
.okr-pbar { width: 60px; height: 3px; background: var(--border); border-radius: 2px; overflow: hidden; }
.okr-pfill { height: 100%; background: var(--accent); }
.okr-pl { font-size: 10px; font-weight: 600; color: var(--muted); }
.kr-body { display: none; padding: 0 14px 10px 38px; border-left: 1.5px solid var(--border); margin-left: 18px; }
.kr-body.open { display: block; }
.kr-row { display: flex; align-items: center; gap: 8px; padding: 6px 0; border-bottom: 1px solid var(--border); }
.kr-ck { width: 16px; height: 16px; border-radius: 50%; border: 1.5px solid var(--border); flex-shrink: 0; }
.kr-ck.done { background: var(--success); border-color: var(--success); }
.kr-ck.done::after { content: ''; display: block; width: 6px; height: 6px; background: #fff; border-radius: 50%; margin: 3px auto 0; }
.kr-tx { font-size: 12px; flex: 1; }
.kr-tx.done { text-decoration: line-through; color: var(--muted); }
.kr-tag { font-size: 9px; font-weight: 600; padding: 1px 5px; border-radius: 3px; }
.kr-tag.q1 { background: oklch(94% 0.008 255); color: var(--accent); }
.kr-tag.q2 { background: oklch(94% 0.008 145); color: var(--success); }
.kr-tag.q3 { background: oklch(94% 0.008 45); color: var(--warning); }

/* 日历 */
.cal-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
.cal-head h2 { font-size: 15px; font-weight: 700; }
.cal-nav { display: flex; gap: 6px; }
.cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 1px; background: var(--border); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
.cal-dow { background: var(--surface); padding: 6px 4px; text-align: center; font-size: 10px; font-weight: 600; color: var(--muted); }
.cal-cell { background: var(--surface); min-height: 50px; padding: 2px 4px; font-size: 10px; }
.cal-cell.out { color: var(--meta); background: var(--bg); }
.cal-cell.today { background: oklch(98% 0.005 255); }
.cal-evt { font-size: 9px; padding: 1px 3px; border-radius: 2px; background: oklch(94% 0.008 255); border-left: 2px solid var(--accent); white-space: nowrap; overflow: hidden; }
.cal-evt.q1 { background: oklch(94% 0.008 25); border-left-color: var(--q1); }
.cal-evt.q2 { background: oklch(94% 0.008 145); border-left-color: var(--q2); }
.cal-evt.q3 { background: oklch(94% 0.008 45); border-left-color: var(--q3); }

/* 甘特 */
.gantt-card { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 14px; margin-bottom: 10px; }
.gantt-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; font-size: 12px; color: var(--muted); }
.gantt-row { display: flex; align-items: center; gap: 8px; padding: 4px 0; }
.gantt-bar { height: 16px; border-radius: 3px; }
.gantt-bar.q1 { background: var(--q1); }
.gantt-bar.q2 { background: var(--q2); }
.gantt-bar.q3 { background: var(--q3); }

/* 通用按钮/输入 */
.btn { display: inline-flex; align-items: center; justify-content: center; padding: 6px 12px; border-radius: 8px; font-size: 13px; font-weight: 500; border: 1px solid var(--border); background: var(--surface); }
.btn-primary { background: var(--accent); color: #fff; border-color: var(--accent); }
.btn-block { width: 100%; }
.input { width: 100%; padding: 6px 10px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface); font-size: 13px; }
.input:focus { border-color: var(--accent); }

/* 空态 */
.empty { padding: 60px 20px; text-align: center; color: var(--muted); }
.empty-icon { font-size: 40px; opacity: 0.5; }
.empty-title { font-size: 15px; font-weight: 600; margin-top: 8px; color: var(--fg); }
.empty-sub { font-size: 12px; margin-top: 4px; }
