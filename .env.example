# Supabase — public
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...

# Supabase — server-side ONLY. Never import from apps/*/src.
# Used by /supabase/functions and CI scripts.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Vercel (for CLI deploys; not needed if using GitHub auto-deploy)
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=

# GitHub (for sub-agents that need to create PRs)
# GITHUB_TOKEN=ghp_...
